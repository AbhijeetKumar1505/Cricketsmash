{
  "name": "cricket-crash",
  "private": true,
  "packageManager": "pnpm@10.5.0",
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.12"
    },
    "shamefullyHoist": true,
    "publicHoistPattern": [
      "@sveltejs/*",
      "svelte"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.10.5",
    "@vitest/ui": "^4.1.5",
    "svelte": "^5.16.0",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "bootstrap": "npx --yes pnpm@10.5.0 install && npx --yes pnpm@10.5.0 run build:packages",
    "build:packages": "npx --yes pnpm@10.5.0 -r --filter \"./packages/*\" run build",
    "build": "npx --yes pnpm@10.5.0 -r run build",
    "test": "npx --yes pnpm@10.5.0 --filter @cricket-crash/fairness run test",
    "test:fairness": "npx --yes pnpm@10.5.0 --filter @cricket-crash/fairness run test",
    "test:fairness:slow": "npx --yes pnpm@10.5.0 --filter @cricket-crash/fairness run test:slow",
    "replay:decomposition": "node ./tools/replay-decomposition.mjs",
    "copy:decoders": "node ./tools/copy-decoders.mjs",
    "compress:glb": "node ./tools/compress-glb.mjs",
    "dev": "npm run build:packages && npx --yes pnpm@10.5.0 --filter @cricket-crash/frontend run dev",
    "dev:frontend": "npm run build:packages && npx --yes pnpm@10.5.0 --filter @cricket-crash/frontend dev",
    "typecheck": "npx --yes pnpm@10.5.0 -r run typecheck",
    "build:frontend": "npm run build:packages && npx --yes pnpm@10.5.0 --filter @cricket-crash/frontend run build"
  }
}
